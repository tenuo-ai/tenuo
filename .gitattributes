# GitHub Linguist configuration
# Controls language statistics displayed on the repository

# Don't count tests in language stats (they inflate Python percentage)
tenuo-python/tests/** linguist-vendored
tenuo-core/tests/** linguist-vendored

# Don't count examples (documentation, not implementation)
tenuo-python/examples/** linguist-documentation

# Don't count generated files
tenuo-core/src/bin/generate_test_vectors.rs linguist-generated

# Don't count notebooks (they show as JSON otherwise)
notebooks/** linguist-documentation

# Don't count benchmarks
benchmarks/** linguist-vendored

# Don't count node_modules (Explorer dependencies)
tenuo-explorer/node_modules/** linguist-vendored

# Don't count WASM generated bindings
tenuo-wasm/pkg/** linguist-generated
tenuo-explorer/src/wasm/** linguist-generated

# Don't count TypeScript declaration files (generated)
*.d.ts linguist-generated

# Explorer is a tooling frontend, not the core SDK
tenuo-explorer/** linguist-vendored

# HTML: all docs/ pages are GitHub Pages templates and the ietf/ file
# is a rendered RFC — neither represents implementation language
docs/** linguist-documentation
ietf/** linguist-documentation

# Scripts and verification helpers are tooling, not the SDK
scripts/** linguist-documentation
docs/formal_verification/z3_bounds.py linguist-documentation
